# --- Discord Tokens ---
# Add as many tokens as you want, numbered from 1.
# Each token runs as a fully independent bot instance.
# DISCORD_TOKEN_1=YOUR_FIRST_TOKEN_HERE
# DISCORD_TOKEN_2=YOUR_SECOND_TOKEN_HERE
# DISCORD_TOKEN_3=YOUR_THIRD_TOKEN_HERE

# Legacy single-token fallback (used if no DISCORD_TOKEN_1 is set)
DISCORD_TOKEN=TOKEN_GOES_HERE

# --- Groq API ---
# Add as many API keys as you want, numbered from 1.
# When a key hits its rate limit, the bot automatically falls back to the next one.
# Once all keys are exhausted, it falls back to the next model in your config.
# GROQ_API_KEY_1=YOUR_FIRST_GROQ_KEY_HERE
# GROQ_API_KEY_2=YOUR_SECOND_GROQ_KEY_HERE
# GROQ_API_KEY_3=YOUR_THIRD_GROQ_KEY_HERE

# Legacy single-key fallback (used if no GROQ_API_KEY_1 is set)
GROQ_API_KEY=GROQ_API_KEY_GOES_HERE
